# ─────────────────────────────────────────────────────────────────────────────
# TEMPLATE DE CONFIGURAÇÃO — copie para .env e preencha com os dados do cliente
# Nunca commite o arquivo .env real (já está no .gitignore)
# ─────────────────────────────────────────────────────────────────────────────

# ─── Supabase ────────────────────────────────────────────────────────────────
# Obtidos em: https://supabase.com/dashboard → Settings → API
VITE_SUPABASE_URL=https://<projeto>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon_key>

# ─── Dados da loja ───────────────────────────────────────────────────────────
VITE_STORE_NAME=Nome da Farmacia
VITE_STORE_SLOGAN=Saude e bem-estar
VITE_STORE_SLUG=nomefarmacia
VITE_STORE_CNPJ=00.000.000/0001-00
VITE_STORE_LEGAL=Nome Farmacia Comercio de Medicamentos LTDA
VITE_STORE_CITY=SAO PAULO

# ─── Pagamentos ───────────────────────────────────────────────────────────────
# true  = modo simulado (para testes sem processar pagamento real)
# false = usa a Edge Function do Supabase com PagHiper real
VITE_MOCK_PAYMENTS=true

# ─── Secrets da Edge Function (configurar no Supabase > Settings > Secrets) ──
# Estes NÃO ficam no .env — são configurados direto no painel do Supabase:
#   PAGHIPER_KEY        = chave da API PagHiper do cliente
#   PAGHIPER_TOKEN      = token PagHiper do cliente
#   NOTIFICATION_URL    = https://dominio-do-cliente.com.br/webhook/paghiper
#   STORE_NAME          = nome da loja (mesmo valor de VITE_STORE_NAME)
